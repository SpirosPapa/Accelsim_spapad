# functional simulator specification
## first two hardcoded
-gpgpu_ptx_instruction_classification 0
-gpgpu_ptx_sim_mode 0
## device prop
-gpgpu_ptx_force_max_capability 80

# Device Limits
## hardcoded
-gpgpu_stack_size_limit 1024
-gpgpu_heap_size_limit 8388608
-gpgpu_runtime_sync_depth_limit 2
-gpgpu_runtime_pending_launch_count_limit 2048
# float lat = (milliseconds * 1000 * CLK_FREQUENCY) / 3;
# miliseconds comes from the latency of launching a 1 TB kernel
-gpgpu_kernel_launch_latency  13148
# hardcoded
-gpgpu_TB_launch_latency 0

# Compute Capability
# from device prop
-gpgpu_compute_capability_major 8
-gpgpu_compute_capability_minor 0

# PTX execution-driven
# hardcoded
-gpgpu_ptx_convert_to_ptxplus 0
-gpgpu_ptx_save_converted_ptxplus 0

# high level architecture configuration
# deviceProp.multiProcessorCount
-gpgpu_n_clusters 56
# hardcoded in system config
-gpgpu_n_cores_per_cluster 1


# get_num_channels(deviceProp.memoryBusWidth, DRAM_MODEL)->(total_memory_width,model)
#   unsigned channel_width =
#      dram_model_bus_width[model] * dram_model_mem_per_ctrlr[model];
# return total_memory_width / channel_width
# static const char *dram_model_str[] = {"none", "GDDR5", "GDDR5X", "GDDR6",
                                       "HBM"};
# static const unsigned dram_model_bus_width[] = {0, 32, 32, 16, 128}; // in bits
# static const unsigned dram_model_mem_per_ctrlr[] = {0, 1, 1, 1, 1};
-gpgpu_n_mem 24


# L2_BANKS_PER_MEM_CHANNEL
-gpgpu_n_sub_partition_per_mchannel 2

# clock domains
#-gpgpu_clock_domains <Core Clock>:<Interconnect Clock>:<L2 Clock>:<DRAM Clock>
#  hw def and dram model
-gpgpu_clock_domains 1440:1440:1440:1215

# shader core pipeline config
# device prop next 3
-gpgpu_shader_registers 65536
-gpgpu_registers_per_block 65536
-gpgpu_occupancy_sm_number 80

# device prop
-gpgpu_shader_core_pipeline 2048:32
-gpgpu_shader_cta 32
# hardcoded
-gpgpu_simd_model 1

# Pipeline widths and number of FUs
# ID_OC_SP,ID_OC_DP,ID_OC_INT,ID_OC_SFU,ID_OC_MEM,OC_EX_SP,OC_EX_DP,OC_EX_INT,OC_EX_SFU,OC_EX_MEM,EX_WB,ID_OC_TENSOR_CORE,OC_EX_TENSOR_CORE
# all from WARP_SCHEDS_PER_SM from hw_def
-gpgpu_pipeline_widths 4,4,4,4,4,4,4,4,4,4,8,4,4
# WARP_SCHEDS_PER_SM next 4
-gpgpu_num_sp_units 4
-gpgpu_num_sfu_units 4
-gpgpu_num_dp_units 4
-gpgpu_num_int_units 4
# deviceProp.major < 6  -> 0 else 1
-gpgpu_tensor_core_avail 1
# deviceProp.major < 6  -> 0 else WARP_SCHEDS_PER_SM
-gpgpu_num_tensor_core_units 4

# Instruction latencies and initiation intervals
# "ADD,MAX,MUL,MAD,DIV"
# All Div operations are executed on SFU unit
-ptx_opcode_latency_int 4,4,4,4,21
-ptx_opcode_initiation_int 2,2,2,2,2
-ptx_opcode_latency_fp 4,4,4,4,39
-ptx_opcode_initiation_fp 2,2,2,2,4
-ptx_opcode_latency_dp 6,6,6,6,330
-ptx_opcode_initiation_dp 4,4,4,4,130
-ptx_opcode_latency_sfu 21
-ptx_opcode_initiation_sfu 8
-ptx_opcode_latency_tesnor 25
-ptx_opcode_initiation_tensor 16

# sub core model: in which each scheduler has its own register file and EUs
# i.e. schedulers are isolated
# hw def
-gpgpu_sub_core_model 1
# disable specialized operand collectors and use generic operand collectors instead
# hardcoded 0 core_config.cu
-gpgpu_enable_specialized_operand_collector 0
# WARP_SCHEDS_PER_SM * 2 next 3
-gpgpu_operand_collector_num_units_gen 8
-gpgpu_operand_collector_num_in_ports_gen 8
-gpgpu_operand_collector_num_out_ports_gen 8
# register banks
# deviceProp.major >= 6
# Runs a Tensor Core microbenchmark to measure how many FMA(fused multiply add) operations per cycle per SM can be issued.
# float fma_bw = tensor_max_flops<half, float>(true);
# unsigned tensor_MACs_per_SM = round_up_2n(fma_bw);
# regfile_bw = tensor_MACs_per_SM * sizeof(half) * 2;
# banks_num = regfile_bw / (WARP_SIZE * 4) / reg_ports
# banks_num = banks_num * 2 if deviceProp.major>3
-gpgpu_num_reg_banks 32
# 2 if major>6 else 1
-gpgpu_reg_file_port_throughput 2


## from hw_def
# warp scheduling
-gpgpu_num_sched_per_core 4
## scheduler decided from extensive search
-gpgpu_scheduler gto
# from hw def
# a warp scheduler issue mode
-gpgpu_max_insn_issue_per_warp 1
## from device prop major  if >3 -> 1
-gpgpu_dual_issue_diff_exec_units 1

## L1/shared memory configuration
# <nsets>:<bsize>:<assoc>,<rep>:<wr>:<alloc>:<wr_alloc>:<set_index_fn>,<mshr>:<N>:<merge>,<mq>:**<fifo_entry>
# ** Optional parameter - Required when mshr_type==Texture Fifo
# In adaptive cache, we adaptively assign the remaining shared memory to L1 cache
# For more info, see https://docs.nvidia.com/cuda/cuda-c-programming-guide/index.html#shared-memory-7-x
# if major >=7 1 else 0
-gpgpu_adaptive_cache_config 1
# hardcoded
-gpgpu_shmem_option 0,8,16,32,64,164
# in hw def
-gpgpu_unified_l1d_size 192
# L1 cache configuration
# WARP_SCHEDS_PER_SM
-gpgpu_l1_banks 4
# is_sector = (deviceProp.major >= 6) ? 'S' : 'N'
# sets hardcoded to 4 after l1_assoc bench
# L1_CACHE_LINE_SIZE 128 from l1_assocc ubench
# assoc = config_l1_size / L1_CACHE_LINE_SIZE / L1_CACHE_SETS
# L:T:m:L:L hardcoded after Volta
# A hardcoded, mshr=warps_num_per_sm *2*L1_CACHE_LINE_SIZE / L1_SECTOR_SIZE , 
# 16,0,32 hardcoded
-gpgpu_cache:dl1 S:4:128:64,L:T:m:L:L,A:512:64,16:0,32
# pointer chase an array <L1_SIZE to find l1_hit latency
-gpgpu_l1_latency 33
# deviceProp.globalL1CacheSupported
-gpgpu_gmem_skip_L1D 0
# hardcoded
-gpgpu_flush_l1_cache 1
# hardcoded
-gpgpu_n_cluster_ejection_buffer_size 32
# 25 if major >=7 else 0
-gpgpu_l1_cache_write_ratio 25

# shared memory  configuration
# deviceProp.sharedMemPerMultiprocessor
-gpgpu_shmem_size 167936
# deviceProp.sharedMemPerMultiprocessor
-gpgpu_shmem_sizeDefault 167936
# deviceProp.sharedMemPerBlock
-gpgpu_shmem_per_block 49152
# pointer chase with only one thread to calculate
-gpgpu_smem_latency 29
# shared memory bankconflict detection
# hardcoded
-gpgpu_shmem_num_banks 32
-gpgpu_shmem_limited_broadcast 0
-gpgpu_shmem_warp_parts 1
# deviceProp.major
-gpgpu_coalesce_arch 80

# L2 cache
# S is_sector=1 
# sets_num = l2_size_per_bank / L2_CACHE_LINE_SIZE / assoc hw_def + mem channel again
# cache_line_size:assoc
# defined 
# set indexing P or X (bitwise xoring) based on l2_size_per_bank l2_banks_num <= ACCELSIM_IPOLY_HASH_SUPPORT or sets_num<=
# by default set indexing is linear(here is X) 
-gpgpu_cache:dl2 S:256:128:16,L:B:m:L:X,A:192:4,32:0,32
# hardcoded
-gpgpu_cache:dl2_texture_only 0
-gpgpu_dram_partition_queues 64:64:64:64
# 1 means data are copied straight to L2 when memcpy is used ,else data are cached on first kernel access 
# measure l2 latency with and without warmup using a pointer chasing array
# if error<10% then l2 is populated on memcpy
-gpgpu_perf_sim_memcpy 1
# unsigned l2_banks_num = mem_channel * L2_BANKS_PER_MEM_CHANNEL;
#    if (isPowerOfTwo(l2_banks_num) &&
#        l2_banks_num <= ACCELSIM_IPOLY_HASH_SUPPORT)
#      std::cout << "-gpgpu_memory_partition_indexing 2" << std::endl;
#    else
#      std::cout << "-gpgpu_memory_partition_indexing 0" << std::endl;
-gpgpu_memory_partition_indexing 0

# 128 KB Inst.
# same as   l2
-gpgpu_cache:il1 N:64:128:16,L:R:f:N:L,S:2:48,4
#WARP_SCHEDS_PER_SM
-gpgpu_inst_fetch_throughput 4
# 128 KB Tex
# Note, TEX is deprected since Volta, It is used for legacy apps only. Use L1D cache instead with .nc modifier or __ldg mehtod
-gpgpu_tex_cache:l1 N:4:128:256,L:R:m:N:L,T:512:8,128:2
# 64 KB Const
# predefined
-gpgpu_const_cache:l1 N:128:64:8,L:R:f:N:L,S:2:64,4
-gpgpu_perfect_inst_const_cache 1

# interconnection
# use built-in local xbar
# all hardcoded except flit size
# L2_BANK_WIDTH_in_BYTE + ACCELSIM_ICNT_CONTROL = 32 + 8 
# 32 in hw_def
-network_mode 2 #local crossbar
# Input queue depth at each router input (one per virtual channel per port)
-icnt_in_buffer_limit 512
-icnt_out_buffer_limit 512
# Number of independent subnetworks
-icnt_subnets 2
# Size (in bytes) of one flit (flow control unit).
-icnt_flit_size 40
# Arbitration algorithm for router scheduling
# 0 round robin , 1 FIFO-based
-icnt_arbiter_algo 1

# memory partition latency config
# lat_2-lat_1
-gpgpu_l2_rop_latency 171
# lat_mem - lat2 
# for lat_mem pointer chase and use cache volatile modifier to ignore the L2 cache
-dram_latency 185

# dram sched config
# defined
-gpgpu_dram_scheduler 1
-gpgpu_frfcfs_dram_sched_queue_size 64
-gpgpu_dram_return_queue_size 192

# dram model config
# predefined based on DRAM_model
-gpgpu_n_mem_per_ctrlr 1
# dram_model_bus_width[DRAM_MODEL] / 8
-gpgpu_dram_buswidth 16
# based on dram_model
-gpgpu_dram_burst_length 2
-dram_data_command_freq_ratio 2
# hardcoded
-gpgpu_mem_address_mask 1
-gpgpu_mem_addr_mapping dramid@8;00000000.00000000.00000000.00000000.0000RRRR.RRRRRRRR.RBBBCCCC.BCCSSSSS

# Mem timing
# DDR_Timing timing = HBM_Timing_1000MHZ or DDR_Timing timing = GDDR5_Timing_1800MHZ;
# based on timing use timing.nbk etc 
-gpgpu_dram_timing_opt nbk=16:CCD=1:RRD=5:RCD=18:RAS=41:RP=18:RC=58:CL=18:WL=3:CDLR=4:WR=15:nbkgrp=4:CCDL=3:RTPL=5
-dram_dual_bus_interface 1

# select lower bits for bnkgrp to increase bnkgrp parallelism
# defined
-dram_bnk_indexing_policy 0
-dram_bnkgrp_indexing_policy 1

#-dram_seperate_write_queue_enable 1
#-dram_write_queue_size 64:56:32

# stat collection
# all predefined
-gpgpu_memlatency_stat 14
-gpgpu_runtime_stat 500
-enable_ptx_file_line_stats 1
-visualizer_enabled 0

# power model configs, disable it untill we create a real energy model
-power_simulation_enabled 0

# tracing functionality
#-trace_enabled 1
#-trace_components WARP_SCHEDULER,SCOREBOARD
#-trace_sampling_core 0
